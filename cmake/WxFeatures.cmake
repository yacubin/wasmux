set(WASMUX_INSTALL_BINDIR "bin")
set(WASMUX_INSTALL_LIBDIR "lib")
set(WASMUX_INSTALL_INCLUDEDIR "include")

if (CONFIG_TARGET_SYSTEM MATCHES "-wasi$")
