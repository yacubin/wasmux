  WX_OPTION(CONFIG_DIRENT_PATH     "Path to dirent standalone"   "${WASMUX_ROOT_DIR}/uapi/dirent"    STRING)
  WX_OPTION(CONFIG_TERMIOS_PATH    "Path to termios standalone"  "${WASMUX_ROOT_DIR}/uapi/termios"   STRING)
  WX_OPTION(CONFIG_ARGP_PATH       "Path to argp standalone"     "${WASMUX_ROOT_DIR}/uapi/argp"      STRING)
